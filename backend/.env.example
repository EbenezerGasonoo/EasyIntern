# Copy to .env and fill in values.
# Production API (api.easyintern.app): set FRONTEND_URL so email links use the live site.

NODE_ENV=development
PORT=5001
DATABASE_URL="mysql://user:pass@localhost:3306/dbname"
JWT_SECRET=change-me

# Public URL of the React app (no trailing slash). Required for verify-email and password-reset links in emails.
FRONTEND_URL=https://easyintern.app
