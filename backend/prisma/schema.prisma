// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "rhel-openssl-3.0.x", "windows"]
  output        = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  COMPANY
  INTERN
  UNIVERSITY
  ADMIN
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  ACCOUNT
  BILLING
  APPLICATION
  JOB_POST
  VERIFICATION
  TECHNICAL
  OTHER
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  SUPPORT_ADMIN
}

enum StudentVerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  userType          UserType
  isEmailVerified   Boolean  @default(false)
  isAdmin           Boolean  @default(false)
  adminRole         AdminRole?
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  isSuspended       Boolean  @default(false)
  suspensionReason  String?
  suspendedAt       DateTime?
  softBannedAt      DateTime?
  /// When set, the account is permanently deleted after this time (3-day grace from request).
  scheduledAccountDeletionAt DateTime? @map("scheduled_account_deletion_at")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company?
  intern  Intern?
  university University?
  notifications Notification[]
  preferences   UserPreference?
  supportTickets SupportTicket[]
  auditLogs AuditLog[] @relation("AuditActor")

  @@map("users")
}

model UserPreference {
  id                           String   @id @default(cuid())
  userId                       String   @unique @map("user_id")
  profileVisibility            String   @default("public") @map("profile_visibility")
  showContactInfo              Boolean  @default(true) @map("show_contact_info")
  notifyJobRecommendations     Boolean  @default(true) @map("notify_job_recommendations")
  notifyApplicationUpdates     Boolean  @default(true) @map("notify_application_updates")
  notifyNewApplicants          Boolean  @default(true) @map("notify_new_applicants")
  notificationChannelEmail     Boolean  @default(true) @map("notification_channel_email")
  notificationChannelInApp     Boolean  @default(true) @map("notification_channel_in_app")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Company {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String
  description      String?
  website          String?
  industry         String?
  location         String?
  phone            String?
  logo             String?
  companyTaxId     String?
  isVerified       Boolean  @default(false)
  registrationDoc  String?  // URL to registration document
  internIntake     String?  // Intern intake per year
  mapLocation      String?  // Google Maps location URL/embed
  benefits         String?  // What we offer interns (e.g. mentorship, stipend)
  hiringPriorities String?  // Roles/teams actively hiring for
  candidateRequirements String? // Qualities/skills sought in candidates
  hiringWorkflow   String?  // Hiring process overview
  companySize      String?  // e.g. "1-10", "11-50", "51-200", "200+"
  contactEmail     String?  // Enquiries from interns
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("companies")
}

model Intern {
  id         String   @id @default(cuid())
  userId     String   @unique
  studentId  String?
  enrollmentYear Int? @map("enrollment_year")
  course String?
  graduationDate DateTime? @map("graduation_date")
  studentVerificationStatus StudentVerificationStatus @default(NOT_SUBMITTED) @map("student_verification_status")
  studentVerificationNotes String? @map("student_verification_notes")
  universityId String? @map("university_id")
  dateOfBirth DateTime?
  ghanaCardNumber String?
  ghanaCardDocument String?
  /// Enrollment letter, official student ID, or similar proof from the school listed under Education (KYI).
  schoolAffiliationDocument String? @map("school_affiliation_document")
  isVerified Boolean @default(false)
  notifyIndustryJobs Boolean @default(false)
  preferredIndustry String?
  firstName  String
  lastName   String
  bio        String?
  phone      String?
  skills     Json     // MySQL-compatible JSON array of skills
  education  String?
  educationWebsite String?
  experience Json?    // Array of experience objects
  location   String?
  resume     String?  // URL to resume file
  profilePic String?  // URL to profile picture
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  university   University?   @relation(fields: [universityId], references: [id], onDelete: SetNull)
  applications Application[]
  verificationRequests StudentVerificationRequest[]

  @@map("interns")
}

model University {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  name                 String
  website              String?
  /// Shown to interns when they select this school (e.g. “Format: GSU-########”).
  studentIdFormatHint  String?  @map("student_id_format_hint") @db.VarChar(512)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogRecords UniversityStudentCatalog[]
  interns Intern[]
  verificationRequests StudentVerificationRequest[]

  @@map("universities")
}

model UniversityStudentCatalog {
  id             String   @id @default(cuid())
  universityId   String   @map("university_id")
  enrollmentYear Int      @map("enrollment_year")
  studentId      String   @map("student_id")
  course         String
  graduationDate DateTime @map("graduation_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  verificationRequests StudentVerificationRequest[]

  @@unique([universityId, studentId])
  @@index([universityId, enrollmentYear])
  @@map("university_student_catalog")
}

model StudentVerificationRequest {
  id                    String                    @id @default(cuid())
  internId              String                    @map("intern_id")
  universityId          String                    @map("university_id")
  catalogRecordId       String?                   @map("catalog_record_id")
  status                StudentVerificationStatus @default(PENDING)
  requestedStudentId    String                    @map("requested_student_id")
  requestedEnrollmentYear Int?                    @map("requested_enrollment_year")
  requestedCourse       String?                   @map("requested_course")
  requestedGraduationDate DateTime?               @map("requested_graduation_date")
  notes                 String?
  reviewedAt            DateTime?                 @map("reviewed_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  intern Intern @relation(fields: [internId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  catalogRecord UniversityStudentCatalog? @relation(fields: [catalogRecordId], references: [id], onDelete: SetNull)

  @@index([universityId, status])
  @@index([internId, status])
  @@map("student_verification_requests")
}

model Job {
  id            String   @id @default(cuid())
  companyId     String
  title         String
  description   String
  requirements  Json
  responsibilities Json
  benefits      Json
  location      String?
  remote        Boolean  @default(false)
  duration      String?  // e.g., "3 months", "6 months"
  stipend       String?  // e.g., "$500/month", "Unpaid"
  skills        Json     // Required skills
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("jobs")
}

model Application {
  id        String            @id @default(cuid())
  jobId     String
  internId  String
  status    ApplicationStatus @default(PENDING)
  coverLetter String?
  appliedAt DateTime          @default(now())
  reviewedAt DateTime?
  updatedAt DateTime           @updatedAt

  job      Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  intern   Intern  @relation(fields: [internId], references: [id], onDelete: Cascade)

  @@unique([jobId, internId])
  @@map("applications")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model SupportTicket {
  id             String         @id @default(cuid())
  requesterUserId String?
  requesterEmail String?
  subject        String
  description    String
  category       TicketCategory @default(OTHER)
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  ownerAdminEmail String?
  dueAt          DateTime?
  internalNotes  String?
  slaBreached    Boolean        @default(false)
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  lastActivityAt DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  requester User? @relation(fields: [requesterUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([ownerAdminEmail])
  @@index([createdAt])
  @@map("support_tickets")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SmtpConfiguration {
  id          String   @id @default(cuid())
  host        String
  port        Int      @default(587)
  secure      Boolean  @default(false)
  username    String
  password    String
  fromName    String   @default("EasyIntern")
  fromEmail   String
  isActive    Boolean  @default(true)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("smtp_configurations")
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}
