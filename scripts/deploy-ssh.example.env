# Copy this file to the repo root as `.deploy.env` (gitignored) and fill in values.
# Then run: powershell -ExecutionPolicy Bypass -File scripts/deploy-ssh.ps1
#
# Requirements: OpenSSH client (scp, ssh) on PATH; Node + npm on the server; existing .env on the API with DATABASE_URL, JWT_SECRET, etc.

# user@hostname or user@ip
EASYINTERN_SSH_TARGET=user@your-server.example.com

# Absolute path on the server where the Node API lives (package.json + prisma/ + src/)
EASYINTERN_REMOTE_API_ROOT=/home/username/api.easyintern.app

# Absolute path where static site files go (contents of frontend dist — index.html, assets/)
EASYINTERN_REMOTE_WEB_ROOT=/home/username/public_html

# Optional: non-default SSH port (scp uses -P, ssh uses -p; script sets both)
# EASYINTERN_SSH_PORT=22

# Optional: private key path if not using ssh-agent
# EASYINTERN_SSH_KEY=C:\Users\You\.ssh\id_ed25519

# Optional: extra shell to run on the server after migrate (e.g. Passenger restart)
# EASYINTERN_SSH_POST=mkdir -p tmp && touch tmp/restart.txt
